      "id": "move-file-into-raw",
      "name": "Move File Into Raw",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        880,
        120
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "REPLACE",
          "name": "Google Drive account"
        }
      }
